# Grafana (fixes blank UI / "failed to load application files" when using a public IP or hostname)
# Set to exactly what you open in the browser, with trailing slash. Example:
# GRAFANA_ROOT_URL=http://137.131.53.98:3000/
# Then: cd docker && docker compose -f docker-compose.yml -f docker-compose.monitoring.yml up -d --force-recreate grafana

# Oracle Instant Client path on host (required for Oracle XStream CDC connector)
# Default: /opt/oracle/instantclient/instantclient_19_30
# Copy to .env and set: ORACLE_INSTANTCLIENT_PATH=/path/to/instantclient_19_30
ORACLE_INSTANTCLIENT_PATH=/opt/oracle/instantclient/instantclient_19_30

# Kafka Connect → Oracle: map database.hostname to a reachable IP inside the connect container.
# Format: hostname:ip (must match "database.hostname" in oracle-xstream-rac-docker.json).
# ORACLE_CONNECT_EXTRA_HOST=racdb-scan.sub01061249390.xstrmconnectdb2.oraclevcn.com:10.0.0.29
