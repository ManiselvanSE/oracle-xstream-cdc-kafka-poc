# Copy to xstream-admin.env (do not commit) and: source xstream-admin.env
# Used by hammerdb-tpcc-onboard-xstream.sh, fix-tpcc-xstream-oracle.sh, ug-prod-onboard-xstream.sh
#
# c##xstrmadmin is NOT the Kafka connector user (c##cfltuser). Passwords are independent.
# Bash note: always quote ORACLE_USER default — : "${ORACLE_USER:="c##xstrmadmin"}"
#            (unquoted c## in := is truncated at #)

export TNS_ADMIN="${TNS_ADMIN:-${HOME}/oracle/network/admin}"
export ORACLE_CONN="${ORACLE_CONN:-RAC_XSTRPDB_POC}"
# Bash: always quote — `export ORACLE_USER=c##xstrmadmin` is wrong (truncates at #).
export ORACLE_USER="c##xstrmadmin"
export ORACLE_PWD='YOUR_C##XSTRMADMIN_PASSWORD'
