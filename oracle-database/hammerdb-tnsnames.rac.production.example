# =============================================================================
# Oracle Net: RAC production-style examples for HammerDB / sqlplus
# Copy to $TNS_ADMIN/tnsnames.ora and replace placeholders.
# Always use SERVICE_NAME for RAC service workloads (not SID).
# =============================================================================

# -----------------------------------------------------------------------------
# Example 1 (PoC): SCAN + SERVICE_NAME — alias matches HammerDB diset connection instance
# -----------------------------------------------------------------------------
RAC_XSTRPDB_POC =
  (DESCRIPTION =
    (LOAD_BALANCE = yes)
    (ADDRESS = (PROTOCOL = TCP)(HOST = racdb-scan.sub01061249390.xstrmconnectdb2.oraclevcn.com)(PORT = 1521))
    (CONNECT_DATA =
      (SERVER = DEDICATED)
      (SERVICE_NAME = XSTRPDB.sub01061249390.xstrmconnectdb2.oraclevcn.com)
    )
  )

# -----------------------------------------------------------------------------
# Example 2: Explicit ADDRESS_LIST with multiple endpoints + client load balance
# and failover. Use when DBA provides SCAN VIPs and/or node VIPs explicitly.
# Replace HOST values with your SCAN FQDN, SCAN IPs, or per-node VIPs.
# -----------------------------------------------------------------------------
RAC_TPCH_MULTI =
  (DESCRIPTION =
    (ADDRESS_LIST =
      (LOAD_BALANCE = on)
      (FAILOVER = on)
      (ADDRESS = (PROTOCOL = TCP)(HOST = rac-scan.yourdomain.com)(PORT = 1521))
      (ADDRESS = (PROTOCOL = TCP)(HOST = 10.0.0.101)(PORT = 1521))
      (ADDRESS = (PROTOCOL = TCP)(HOST = 10.0.0.102)(PORT = 1521))
    )
    (CONNECT_DATA =
      (SERVER = DEDICATED)
      (SERVICE_NAME = your.service.name)
    )
  )

# -----------------------------------------------------------------------------
# Optional: sqlnet.ora (same directory as tnsnames.ora)
# SQLNET.AUTHENTICATION_SERVICES = (NONE)
# NAMES.DIRECTORY_PATH = (TNSNAMES, EZCONNECT)
